---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'AI agent skills to operate your Shopify store with extended capabilities. Works with Claude Code, Cursor, Cline, Copilot, and Gemini CLI.',
  ogImage = 'https://skills.40rty.ai/40rty-logo.png',
  type = 'website',
  jsonLd,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonicalUrl = Astro.url.href;
const siteName = 'Shopify Admin Skills';
const siteUrl = 'https://skills.40rty.ai';

const defaultSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'TechArticle' : 'WebPage',
  name: title,
  description,
  url: canonicalUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: siteName,
    url: siteUrl,
    publisher: {
      '@type': 'Organization',
      name: '40rty',
      url: 'https://40rty.ai',
    },
  },
};

const schemas: Record<string, unknown>[] = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : [defaultSchema];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

    <!-- Open Graph -->
    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@40rtyAI" />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href={`${base}40rty-mark.png`} />
    
    <!-- JSON-LD structured data -->
    {schemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YQXK1GQEGB"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YQXK1GQEGB', {
        page_title: document.title,
        page_location: window.location.href,
      });
    </script>
  </head>
  <body>
    <!-- Page-wide gradient mesh -->
    <div class="page-mesh">
      <div class="mesh-orb mesh-1"></div>
      <div class="mesh-orb mesh-2"></div>
      <div class="mesh-orb mesh-3"></div>
    </div>

    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .page-mesh {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .mesh-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    animation: drift 16s ease-in-out infinite;
  }

  .mesh-1 {
    width: 700px;
    height: 700px;
    background: var(--color-accent);
    opacity: 0.25;
    top: -200px;
    right: -150px;
    animation-delay: 0s;
  }

  .mesh-2 {
    width: 500px;
    height: 500px;
    background: var(--color-accent-light);
    opacity: 0.2;
    bottom: 10%;
    left: -100px;
    animation-delay: -6s;
  }

  .mesh-3 {
    width: 400px;
    height: 400px;
    background: var(--color-dark);
    opacity: 0.03;
    top: 40%;
    right: 20%;
    animation-delay: -10s;
  }

  @keyframes drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, -30px) scale(1.06); }
    66% { transform: translate(-30px, 20px) scale(0.94); }
  }

  body > *:not(.page-mesh) {
    position: relative;
    z-index: 1;
  }

  .footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 999;
    border-top: 1px solid var(--color-card-border);
    padding: 8px 40px;
    background: rgba(250, 250, 250, 0.85);
    backdrop-filter: blur(10px);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
  }

  .footer-logo-img {
    height: 20px;
    width: auto;
  }

  .footer-sep { opacity: 0.4; }
  .footer a:hover { color: var(--color-dark); }

  @media (max-width: 768px) {
    .footer { padding: 6px 16px; }
    .footer-inner { gap: 10px; font-size: 0.65rem; }
    .footer-logo-img { height: 14px; }
    .mesh-1 { width: 400px; height: 400px; }
    .mesh-2 { width: 300px; height: 300px; }
  }
</style>
