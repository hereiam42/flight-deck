---
import Base from '../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';

const base = import.meta.env.BASE_URL;

const skillsRoot = path.resolve(process.cwd(), '../skills');
const categories = fs.readdirSync(skillsRoot).filter((d: string) =>
  fs.statSync(path.join(skillsRoot, d)).isDirectory()
);

interface Skill {
  name: string;
  description: string;
  category: string;
  categorySlug: string;
  slug: string;
}

const skills: Skill[] = [];
for (const cat of categories) {
  const catPath = path.join(skillsRoot, cat);
  const skillDirs = fs.readdirSync(catPath).filter((d: string) =>
    fs.statSync(path.join(catPath, d)).isDirectory()
  );
  for (const skill of skillDirs) {
    const skillFile = path.join(catPath, skill, 'SKILL.md');
    if (fs.existsSync(skillFile)) {
      const content = fs.readFileSync(skillFile, 'utf-8');
      const { data } = matter(content);
      skills.push({
        name: data.name || skill,
        description: data.description || '',
        category: cat.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
        categorySlug: cat,
        slug: skill,
      });
    }
  }
}

const categoryColors: Record<string, string> = {
  'Marketing': '#E8A838',
  'Merchandising': '#5B8DEF',
  'Customer Support': '#E85D75',
  'Customer Ops': '#9B6EE3',
  'Conversion Optimization': '#3DBB8F',
  'Fulfillment Ops': '#E87838',
  'Finance': '#5BB8A8',
  'Order Intelligence': '#D4605A',
  'Returns': '#8B8B8B',
  'Store Management': '#6B8CA8',
};

const categoryLabels: Record<string, string> = {
  'Marketing': 'Marketing',
  'Merchandising': 'Catalog & Inventory',
  'Customer Support': 'Support',
  'Customer Ops': 'Customer Ops',
  'Conversion Optimization': 'Conversion',
  'Fulfillment Ops': 'Fulfillment',
  'Finance': 'Finance',
  'Order Intelligence': 'Order Intel',
  'Returns': 'Returns',
  'Store Management': 'Store Mgmt',
};

const categoryIcons: Record<string, string> = {
  'Marketing': '📣',
  'Merchandising': '📦',
  'Customer Support': '💬',
  'Customer Ops': '👥',
  'Conversion Optimization': '📈',
  'Fulfillment Ops': '🚚',
  'Finance': '💰',
  'Order Intelligence': '🛡️',
  'Returns': '↩️',
  'Store Management': '⚙️',
};

// Shuffle and split into 2 columns, tripled for seamless loop
const shuffled = [...skills].sort(() => Math.random() - 0.5);
const half = Math.ceil(shuffled.length / 2);
const col1Base = shuffled.slice(0, half);
const col2Base = shuffled.slice(half);
const row1 = [...col1Base, ...col1Base, ...col1Base];
const row2 = [...col2Base, ...col2Base, ...col2Base];

const installPrompt = `Please guide me through setting up Shopify Admin Skills. Act as a concierge: walk me through each step one at a time, keep your messages short and friendly, and DO NOT paste raw command output, logs, or stack traces into the chat. Summarize results in one line ("✅ plugins installed", "✅ connected to my-store"). Only surface details if something actually fails, and then only the relevant error.

Follow these steps in order, confirming each before moving on:

Step 1 — Tell me you're about to install two plugins (Shopify AI Toolkit + Shopify Admin Skills), then run these silently and report a single ✅ when done:
  claude plugin marketplace add Shopify/Shopify-AI-Toolkit
  claude plugin install shopify-plugin@shopify-ai-toolkit
  claude plugin marketplace add 40RTY-ai/shopify-admin-skills
  claude plugin install shopify-admin-skills@shopify-admin-skills

Step 2 — Silently verify with "claude plugin list" that both plugins are present. Don't show me the list; just confirm "✅ both plugins active".

Step 3 — Ask me (one question at a time, conversationally):
  a) What's your store domain? (e.g. my-store.myshopify.com)
  b) Want to use the default scope set, or customize? Default covers products, orders, customers, inventory, discounts, fulfillments, returns, price rules, publications, and payouts.

Then run auth silently. Use EXACTLY this scope string for the default (do not abbreviate or invent scopes — Shopify will reject unknown scopes like "read_payouts"):
  read_products,write_products,read_orders,write_orders,read_customers,write_customers,read_inventory,write_inventory,read_discounts,write_discounts,read_fulfillments,write_fulfillments,read_returns,write_returns,read_price_rules,write_price_rules,read_publications,write_publications,read_shopify_payments_payouts

Command:
  shopify store auth --store <domain> --scopes <scopes>
and confirm with a one-line "✅ connected to <domain>".

Step 4 — Now guide me into actually using the skills. Present a short menu (3–5 options) of guided examples tailored to what the skills can do, like:
  • "Find variants with low inventory and export a restock list"
  • "Show abandoned checkouts from the last 7 days"
  • "Audit products missing SEO titles or descriptions"
  • "Rank my top products by revenue this month"
  • "Find duplicate customer records"

For each, give a one-sentence description. Ask me to pick one (or describe my own goal), then run the matching skill — again, quietly, reporting results as a clean summary, not raw JSON.

Throughout: you're my guide. Ask, confirm, execute, summarize. No walls of text, no logs, no "here's what I ran" unless I ask.`;
---

<Base
  title="Shopify Admin Skills — AI agent skills for your store"
  description={`${skills.length}+ pre-built AI agent skills for Shopify store operators. Recover carts, adjust prices, audit inventory, process refunds and more — directly through Claude Code, Cursor, Cline, Copilot, or Gemini CLI.`}
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Shopify Admin Skills',
      url: 'https://skills.40rty.ai',
      description: `${skills.length}+ pre-built AI agent skills for Shopify store operators.`,
      publisher: { '@type': 'Organization', name: '40rty', url: 'https://40rty.ai' },
    },
    {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'Shopify Admin Skills',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Claude Code, Cursor, Cline, Copilot, Gemini CLI',
      url: 'https://skills.40rty.ai',
      downloadUrl: 'https://github.com/40RTY-ai/shopify-admin-skills',
      license: 'https://opensource.org/licenses/MIT',
      description: `${skills.length}+ pre-built AI agent skills for Shopify: cart recovery, bulk pricing, inventory audits, refunds, fulfillment routing, SEO, and more.`,
      author: { '@type': 'Organization', name: '40rty', url: 'https://40rty.ai' },
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    },
  ]}
>


  <!-- HERO — split layout: left title, right skills grid -->
  

  <a href="https://github.com/40RTY-ai/shopify-admin-skills" target="_blank" rel="noopener" class="gh-top">
    <div class="gh-icon-wrapper">
      <svg class="gh-icon-gh" width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      <svg class="gh-icon-star" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    </div>
    <span>Star to support us</span>
    <span id="gh-count-container" style="display: none; align-items: center; gap: 6px; margin-left: 4px; padding-left: 10px; border-left: 1px solid rgba(255,255,255,0.2);">
      <span id="gh-stars"></span>
    </span>
  </a>
  <section class="hero">
    <div class="hero-split">
      <div class="hero-left">
        
        <h1 class="hero-title">
          <span class="line typewriter" id="t1">Shopify</span>
          <span class="line stroke typewriter" id="t2">Admin</span>
          <span class="line typewriter" id="t3">Skills<span class="dot">.</span></span>
        </h1>
        <p class="hero-sub">
          <a id="rotating-link" href="#"><span id="rotating-text"></span></a>
        </p>
        <p class="hero-sub-static">through your AI agent.</p>
        <div class="hero-cta">
          <div class="install-tabs">
            <button class="tab active" data-tab="claude-code">
              <img src="/claude-logo.svg" alt="" class="tab-icon" width="14" height="14" />
              Claude Code
            </button>
            <button class="tab" data-tab="cli">
              <svg class="tab-icon tab-icon-terminal" width="14" height="14" viewBox="0 0 16 16" aria-hidden="true">
                <rect x="0.5" y="1.5" width="15" height="13" rx="1.5" fill="#1d1d1f" stroke="#1d1d1f"/>
                <path d="M3.2 5.2L5.8 7.8 3.2 10.4" stroke="#ffffff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <line x1="7" y1="10.6" x2="11.5" y2="10.6" stroke="#ffffff" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              Terminal
            </button>
          </div>

          <div class="install-panel" data-panel="claude-code">
            <p class="install-hint">
              Paste into Claude Code — it'll install everything for you.
            </p>
            <div class="prompt-wrap">
              <button class="cmd cmd-prompt" data-cmd={installPrompt} data-tooltip={installPrompt.slice(0, 120) + '…'}>
                <span class="cmd-dollar">✨</span>
                <code>Install Shopify Admin Skills for me</code>
                <span class="cmd-copy"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></span>
                <span class="cmd-toast">Copied!</span>
              </button>
            </div>
          </div>

          <div class="install-panel" data-panel="cli" hidden>
            <button class="cmd" data-cmd="npx skills add 40RTY-ai/shopify-admin-skills">
              <span class="cmd-dollar">$</span>
              <code>npx skills add 40RTY-ai/shopify-admin-skills</code>
              <span class="cmd-copy"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></span>
              <span class="cmd-toast">Copied!</span>
            </button>
            <p class="cmd-hint">Works with Cursor, Cline, Copilot, Gemini CLI.</p>
          </div>

          <a href="https://40rty.ai" target="_blank" rel="noopener" class="built-by">
            Built by <img src="/40rty-logo.png" alt="40rty" class="built-by-logo" /> agents
          </a>
        </div>
      </div>

      <!-- Right side: skills grid scrolling vertically -->
      <a href="#signup" class="signup-teaser mobile-teaser">
        Tell me more cool stuff
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="teaser-arrow"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
      </a>

      <div class="hero-right">
        <div class="skills-scroll-mask">
          <div class="skills-scroll-col col-up">
            {row1.map(s => (
              <a href={`${base}skills/${s.categorySlug}/${s.slug}/`} class="s-chip">
                <span class="s-cat" style={`color: ${categoryColors[s.category] || '#888'}; background: ${categoryColors[s.category] || '#888'}15;`}>{categoryIcons[s.category] || ''} {categoryLabels[s.category] || s.category}</span>
                <code class="s-name">{s.name}</code>
              </a>
            ))}
          </div>
          <div class="skills-scroll-col col-down">
            {row2.map(s => (
              <a href={`${base}skills/${s.categorySlug}/${s.slug}/`} class="s-chip">
                <span class="s-cat" style={`color: ${categoryColors[s.category] || '#888'}; background: ${categoryColors[s.category] || '#888'}15;`}>{categoryIcons[s.category] || ''} {categoryLabels[s.category] || s.category}</span>
                <code class="s-name">{s.name}</code>
              </a>
            ))}
          </div>
        </div>
        <a href={`${base}skills/`} class="browse-link">Browse all {skills.length} skills &rarr;</a>
      </div>
    </div>

    <a href="#signup" class="signup-teaser">
      Tell me more cool stuff
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="teaser-arrow"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
    </a>
  </section>

  <!-- SIGNUP SECTION -->
  <section class="signup" id="signup">
    <div class="signup-card">
      <span class="signup-eyebrow signup-eyebrow-flex">From <img src="/40rty-logo.png" alt="40rty" class="signup-eyebrow-logo" /></span>
      <h2 class="signup-heading">Get new skills first.</h2>
      <p class="signup-desc">New agent skills, operator playbooks, and updates from the 40rty team — straight to your inbox.</p>
      <!-- Step 1: email -->
      <div id="signup-step1">
        <form class="signup-form" id="signup-form" novalidate>
          <div class="signup-row">
            <input
              type="email"
              name="email"
              id="signup-email"
              placeholder="your@email.com"
              required
              class="signup-input"
              autocomplete="email"
            />
            <button type="submit" class="signup-btn">Get updates</button>
          </div>
          <p class="signup-fine">No spam. Unsubscribe any time.</p>
        </form>
      </div>

      <!-- Step 2: skill request (shown after email captured) -->
      <div id="signup-step2" class="signup-step2">
        <p class="step2-label">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          You're in! Tell us a bit more.
        </p>
        <form class="signup-form" id="skill-request-form" novalidate>
          <div class="step2-fields">
            <input
              type="text"
              id="domain-input"
              placeholder="Your store domain (e.g. my-store.myshopify.com)"
              class="signup-input"
            />
            <input
              type="text"
              id="skill-request-input"
              placeholder="Any skill you'd love to see?"
              class="signup-input"
            />
            <button type="submit" class="signup-btn step2-submit">Send</button>
          </div>
        </form>
        <button type="button" id="skip-btn" class="skip-link">Skip &rarr;</button>
      </div>

      <!-- Final success -->
      <div class="signup-success" id="signup-success">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <span>You're in — we'll be in touch.</span>
      </div>
    </div>
  </section>

  <script>
    // Fetch GitHub stars
    fetch('https://api.github.com/repos/40RTY-ai/shopify-admin-skills')
      .then(res => res.json())
      .then(data => {
        const el = document.getElementById('gh-stars');
        if (el && data.stargazers_count !== undefined) {
          el.textContent = data.stargazers_count.toLocaleString();
          const container = document.getElementById('gh-count-container');
          if (container) container.style.display = 'flex';
        }
      })
      .catch(e => console.error('Failed to fetch github stars', e));

    // Copy buttons — handle both .cmd and .prompt-box
    document.querySelectorAll<HTMLButtonElement>('[data-cmd]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const cmd = btn.getAttribute('data-cmd') || '';
        await navigator.clipboard.writeText(cmd);
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      });
    });

    // Expand/collapse full prompt
    const expandBtn = document.querySelector<HTMLButtonElement>('.prompt-expand-btn');
    const promptFull = document.getElementById('prompt-full');
    expandBtn?.addEventListener('click', () => {
      if (!promptFull) return;
      const expanded = expandBtn.getAttribute('aria-expanded') === 'true';
      expandBtn.setAttribute('aria-expanded', (!expanded).toString());
      promptFull.hidden = expanded;
    });

    // Install tabs
    document.querySelectorAll<HTMLButtonElement>('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        document.querySelectorAll<HTMLElement>('.install-panel').forEach(p => {
          const shouldShow = p.getAttribute('data-panel') === target;
          p.hidden = !shouldShow;
          if (shouldShow) {
            // Restart animation
            p.style.animation = 'none';
            void p.offsetWidth; // trigger reflow
            p.style.animation = '';
          }
        });
      });
    });

    // Typewriter reveal
    const lines = [
      document.getElementById('t1'),
      document.getElementById('t2'),
      document.getElementById('t3'),
    ];
    lines.forEach((el, i) => {
      if (!el) return;
      el.style.animationDelay = `${i * 0.4}s`;
      el.classList.add('reveal');
    });

    // Rotating subtitle — [text, skill-path]
    const base = (document.querySelector('base')?.href || '/').replace(location.origin, '') || '/';
    const abilities: [string, string][] = [
      ['Recover abandoned carts', 'skills/marketing/abandoned-cart-recovery/'],
      ['Bulk-adjust prices across collections', 'skills/merchandising/bulk-price-adjustment/'],
      ['Audit inventory across locations', 'skills/merchandising/multi-location-inventory-audit/'],
      ['Process refunds and reorders', 'skills/customer-support/refund-and-reorder/'],
      ['Tag customers by spend tier', 'skills/customer-ops/customer-spend-tier-tagger/'],
      ['Detect duplicate SKUs and barcodes', 'skills/merchandising/duplicate-sku-barcode-detector/'],
      ['Analyze return reasons', 'skills/returns/return-reason-analysis/'],
      ['Route fulfillments by location', 'skills/fulfillment-ops/fulfillment-location-routing/'],
      ['Track delivery SLAs', 'skills/fulfillment-ops/delivery-time-analysis/'],
      ['Clean up stale discount codes', 'skills/store-management/discount-hygiene-cleanup/'],
      ['Export loyalty segments', 'skills/marketing/loyalty-segment-export/'],
      ['Generate revenue-by-location reports', 'skills/finance/revenue-by-location-report/'],
      ['Find dead stock eating warehouse costs', 'skills/merchandising/dead-stock-identifier/'],
      ['Audit SEO metadata across products', 'skills/merchandising/seo-metadata-audit/'],
    ];

    const rotEl = document.getElementById('rotating-text');
    const rotLink = document.getElementById('rotating-link') as HTMLAnchorElement | null;
    let currentIdx = 0;
    let typeInterval: number | null = null;
    let eraseTimeout: number | null = null;
    let rotateInterval: number | null = null;

    function clearTimers() {
      if (typeInterval !== null) { clearInterval(typeInterval); typeInterval = null; }
      if (eraseTimeout !== null) { clearTimeout(eraseTimeout); eraseTimeout = null; }
    }

    function typeText(text: string, el: HTMLElement) {
      if (typeInterval !== null) clearInterval(typeInterval);
      el.textContent = '';
      let i = 0;
      typeInterval = window.setInterval(() => {
        el.textContent = text.slice(0, i + 1);
        i++;
        if (i >= text.length && typeInterval !== null) {
          clearInterval(typeInterval);
          typeInterval = null;
        }
      }, 35);
    }

    function updateLink(idx: number) {
      if (rotLink) rotLink.href = base + abilities[idx][1];
    }

    function eraseAndType() {
      if (!rotEl || document.hidden) return;
      clearTimers();
      rotEl.style.opacity = '0';
      eraseTimeout = window.setTimeout(() => {
        currentIdx = (currentIdx + 1) % abilities.length;
        rotEl.style.opacity = '1';
        updateLink(currentIdx);
        typeText(abilities[currentIdx][0], rotEl);
      }, 300);
    }

    function startRotation() {
      if (rotateInterval !== null) clearInterval(rotateInterval);
      rotateInterval = window.setInterval(eraseAndType, 3500);
    }

    if (rotEl) {
      updateLink(0);
      typeText(abilities[0][0], rotEl);
      startRotation();
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        clearTimers();
        if (rotateInterval !== null) { clearInterval(rotateInterval); rotateInterval = null; }
      } else if (rotEl) {
        rotEl.style.opacity = '1';
        typeText(abilities[currentIdx][0], rotEl);
        startRotation();
      }
    });

    const apiBase = import.meta.env.DEV ? 'http://localhost:3000' : 'https://audit.40rty.ai';
    let capturedEmail = '';

    function showSuccess() {
      document.getElementById('signup-step2')?.classList.remove('visible');
      document.getElementById('signup-success')?.classList.add('visible');
    }

    // Step 1 — email
    const signupForm = document.getElementById('signup-form') as HTMLFormElement | null;
    const signupBtn = signupForm?.querySelector('.signup-btn') as HTMLButtonElement | null;

    signupForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('signup-email') as HTMLInputElement | null;
      const email = emailInput?.value?.trim();
      if (!email) return;

      capturedEmail = email;
      if (signupBtn) { signupBtn.textContent = 'Sending…'; signupBtn.disabled = true; }

      fetch(`${apiBase}/api/skills-signup`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      }).catch(() => {});

      if (typeof gtag !== 'undefined') {
        gtag('event', 'skills_signup', { method: 'email' });
      }

      // Move to step 2
      document.getElementById('signup-step1')?.classList.add('done');
      setTimeout(() => {
        document.getElementById('signup-step1')?.classList.add('hidden');
        document.getElementById('signup-step2')?.classList.add('visible');
        document.getElementById('skill-request-input')?.focus();
      }, 300);
    });

    // Step 2 — skill request
    const skillRequestForm = document.getElementById('skill-request-form') as HTMLFormElement | null;

    skillRequestForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const skillRequest = (document.getElementById('skill-request-input') as HTMLInputElement | null)?.value?.trim();
      const domain = (document.getElementById('domain-input') as HTMLInputElement | null)?.value?.trim();
      if (skillRequest || domain) {
        fetch(`${apiBase}/api/skills-signup`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: capturedEmail, skillRequest, domain }),
        }).catch(() => {});
        if (typeof gtag !== 'undefined') {
